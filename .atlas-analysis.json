  "keyFeatures": [
    "Multi-workspace management with tenant isolation",
    "Complete product catalog with pricing and stock tracking",
    "Real-time inventory management with transfers",
    "Comprehensive invoicing system with PDF generation",
    "Quotation creation and conversion to invoices",
    "Contact management for customers and suppliers",
    "Tax configuration and calculations",
    "Workflow automation with visual builder",
    "Multi-currency support",
    "Role-based access control"
