    "InvoiceController@index - List invoices",
    "InvoiceController@store - Create invoice",
    "InvoiceController@show - Get invoice",
    "InvoiceController@update - Update invoice",
    "QuotationController@index - List quotations",
    "QuotationController@store - Create quotation",
    "ProductController@index - List products",
    "ProductController@store - Create product",
    "ContactController@index - List contacts",
    "ContactController@store - Create contact",
    "StockTransferController - Manage inventory transfers",
